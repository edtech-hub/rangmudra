# Rangmudra server config — copy to .env and fill in.

# MongoDB Atlas connection string (required).
# Example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Database name (default: rangmudra).
MONGODB_DB=rangmudra

# Admin passcode (default: rangmudra-admin). Change in production.
ADMIN_PASSCODE=rangmudra-admin

# HTTP port (default: 3000).
PORT=3000
